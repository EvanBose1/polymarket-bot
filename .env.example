# Copy to .env and fill in. NEVER commit your .env file.
# Polygon private key for the wallet that holds your USDC
POLY_PK=0xYOUR_PRIVATE_KEY_HERE

# Your Polymarket proxy/funder address (find in Polymarket UI -> Profile)
POLY_FUNDER=0xYOUR_FUNDER_ADDRESS

# 1 = paper trade (logs only), 0 = live trading
DRY_RUN=1

# Optional: comma-separated wallet addresses to copy-trade.
# Leave blank to auto-pull top traders from the leaderboard.
WATCH=
